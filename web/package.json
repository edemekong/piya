{
  "name": "1bee-web",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @1bee/admin --filter @1bee/portal dev",
    "dev:admin": "pnpm --filter @1bee/admin dev",
    "dev:portal": "pnpm --filter @1bee/portal dev",
    "build": "pnpm -r build",
    "build:admin": "pnpm --filter @1bee/admin build",
    "build:portal": "pnpm --filter @1bee/portal build",
    "start:admin": "pnpm --filter @1bee/admin start",
    "start:portal": "pnpm --filter @1bee/portal start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
