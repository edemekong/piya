{
  "name": "piya-web",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @piya/admin --filter @piya/portal dev",
    "dev:admin": "pnpm --filter @piya/admin dev",
    "dev:portal": "pnpm --filter @piya/portal dev",
    "build": "pnpm -r build",
    "build:admin": "pnpm --filter @piya/admin build",
    "build:portal": "pnpm --filter @piya/portal build",
    "deploy:admin": "railway up",
    "start:admin": "pnpm --filter @piya/admin start",
    "start:portal": "pnpm --filter @piya/portal start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
